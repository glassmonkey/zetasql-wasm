# Bazel cache configuration for Docker persistence
# Repository cache: Downloaded external dependencies (git repos, http archives, etc.)
build --repository_cache=/home/builder/.cache/bazel/repository_cache
# Disk cache: Build artifacts and action outputs
build --disk_cache=/home/builder/.cache/bazel/disk_cache

# Enable MODULE.bazel-based dependency management (common to all commands)
common --enable_bzlmod

# Debug flags (common to all commands)
common --verbose_failures
common --experimental_ui_max_stdouterr_bytes=-1

# Required for using Emscripten toolchain
build --incompatible_enable_cc_toolchain_resolution

# Required for using prebuilt protoc toolchain (Bazel 7+)
common --incompatible_enable_proto_toolchain_resolution

# ZetaSQL requires C++20
build --cxxopt=-std=c++20
build --host_cxxopt=-std=c++20
build --action_env=BAZEL_CXXOPTS="-std=c++20"

# Fix for absolute path inclusion errors in Docker environment
# Safe to disable in isolated Docker builds
# References:
#   - https://github.com/bazelbuild/bazel/issues/21718
#   - https://pigweed.dev/blog/09-bazel-relative-toolchain-paths.html
build --features=-layering_check
build --host_features=-layering_check

# Clang-compatible flag for relative paths (works with Emscripten)
build --copt=-no-canonical-prefixes
build --host_copt=-no-canonical-prefixes

# Java runtime specification (ZetaSQL official configuration)
build --java_runtime_version=remotejdk_11

# Build optimization
build --copt=-O3
build --copt=-DNDEBUG

# Warning suppression (applying ZetaSQL official clang settings)
build --cxxopt=-Wno-module-import-in-extern-c
build --cxxopt=-Wno-deprecated-declarations
build --cxxopt=-Wno-range-loop-analysis
build --cxxopt=-Wno-inconsistent-missing-override
build --cxxopt=-Wno-char-subscripts
build --cxxopt=-Wno-enum-compare-switch
build --cxxopt=-Wno-defaulted-function-deleted
build --cxxopt=-Wno-unused-private-field
build --cxxopt=-Wno-return-std-move
build --cxxopt=-Wno-reorder-ctor
build --cxxopt=-Wno-unused-const-variable
build --cxxopt=-Wno-unused-function
build --cxxopt=-Wno-macro-redefined
build --cxxopt=-Wno-sign-compare
